# ─── Supabase (required) ──────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Migration automation (required for vercel-build script) ──────────────────
# Project ref: the subdomain part of your Supabase URL (e.g. "abcdefghijklmnop")
SUPABASE_PROJECT_REF=your-project-ref

# Personal access token: supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# ─── Resend (email notifications) ─────────────────────────────────────────────
# From: resend.com/api-keys
RESEND_API_KEY=re_...

# The "from" address for all outbound emails (must be a verified domain in Resend)
# Example: Folio <notifications@folio.cafe>
EMAIL_FROM=Folio <notifications@folio.cafe>

# Public app URL (used in email links)
NEXT_PUBLIC_APP_URL=https://folio.cafe

# ─── Paystack (payments) ──────────────────────────────────────────────────────
# From: dashboard.paystack.com/settings/developer
# Public key is safe to expose in the browser; secret key must stay server-side.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_SECRET_KEY=sk_live_...
