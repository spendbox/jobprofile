generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL is set in prisma.config.ts from DATABASE_URL / DIRECT_URL env vars
}

// ─── Models ───────────────────────────────────────────────────────────────────

model UserProfile {
  id                       String   @id @db.Uuid
  full_name                String
  user_role                String
  company_name             String?
  avatar_url               String?
  is_verified              Boolean? @default(false)
  verified_at              DateTime? @db.Timestamptz(6)
  company_website          String?
  company_contact_email    String?
  company_description      String?
  company_hq_country       String?
  company_hq_state         String?
  company_timezone         String?
  company_profile_complete Boolean? @default(false)
  created_at               DateTime @default(now()) @db.Timestamptz(6)

  profiles      Profile[]
  sent_requests InterviewRequest[] @relation("EmployerRequests")
  talent_finds  TalentFind[]

  @@map("user_profiles")
}

model Profile {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String   @db.Uuid
  role_title              String
  bio                     String?
  skills                  String[]
  years_experience        Int      @default(0)
  salary_expectation      Int?
  location                String?
  timezone                String?
  availability_status     String   @default("open")
  portfolio_url           String?
  cv_url                  String?
  intro_video_url         String?
  profile_views           Int      @default(0)
  times_shown             Int      @default(0)
  availability_updated_at DateTime @default(now()) @db.Timestamptz(6)
  created_at              DateTime @default(now()) @db.Timestamptz(6)
  updated_at              DateTime @default(now()) @db.Timestamptz(6)

  user                    UserProfile             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  interview_requests      InterviewRequest[]
  views                   ProfileView[]
  talent_find_candidates  TalentFindCandidate[]

  @@map("profiles")
}

model TalentFind {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employer_id       String   @db.Uuid
  role_title        String
  employment_type   String   // 'fulltime'|'parttime'|'contract'|'volunteer'|'internship'
  work_arrangement  String   // 'remote'|'hybrid'|'onsite'
  hiring_country    String?
  hiring_state      String?
  min_experience    Int?
  max_experience    Int?
  skills            String[]
  salary_min        Int?
  salary_max        Int?
  description       String
  requirements_text String?
  custom_questions  Json     @default("[]")
  status            String   @default("active") // 'active'|'archived'
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  employer            UserProfile           @relation(fields: [employer_id], references: [id], onDelete: Cascade)
  candidates          TalentFindCandidate[]
  interview_requests  InterviewRequest[]

  @@map("talent_finds")
}

model TalentFindCandidate {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  talent_find_id String   @db.Uuid
  profile_id     String   @db.Uuid
  ai_score       Int      @default(0)
  ai_summary     String?
  contacted      Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  talent_find TalentFind @relation(fields: [talent_find_id], references: [id], onDelete: Cascade)
  profile     Profile    @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@unique([talent_find_id, profile_id])
  @@map("talent_find_candidates")
}

model JobOpening {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employer_id String   @db.Uuid
  title       String
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  requests InterviewRequest[]

  @@map("job_openings")
}

model InterviewRequest {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employer_id      String   @db.Uuid
  profile_id       String   @db.Uuid
  status           String   @default("pending")
  stage            String   @default("discovered")
  message          String?
  notes            String?
  archived         Boolean  @default(false)
  opening_id       String?  @db.Uuid
  talent_find_id   String?  @db.Uuid
  star_rating      Int?
  question_answers Json?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  employer     UserProfile @relation("EmployerRequests", fields: [employer_id], references: [id], onDelete: Cascade)
  profile      Profile     @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  opening      JobOpening? @relation(fields: [opening_id], references: [id], onDelete: SetNull)
  talent_find  TalentFind? @relation(fields: [talent_find_id], references: [id], onDelete: SetNull)

  @@unique([employer_id, profile_id])
  @@map("interview_requests")
}

model ProfileView {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profile_id String   @db.Uuid
  viewer_id  String?  @db.Uuid
  viewed_at  DateTime @default(now()) @db.Timestamptz(6)

  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("profile_views")
}
